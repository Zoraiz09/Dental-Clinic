{
  "expo": {
    "name": "Noor Dentofacial",
    "slug": "noor-dentofacial",
    "owner": "noordentalclinic",
    "scheme": "noorclinic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "clinic.noor.dentofacial",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture patient photos and scan inventory barcodes.",
        "NSPhotoLibraryUsageDescription": "Attach patient photos and expense receipts.",
        "NSFaceIDUsageDescription": "Unlock the app securely with Face ID."
      }
    },
    "android": {
      "package": "clinic.noor.dentofacial",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#F8FAF9",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-camera",
      "expo-image-picker",
      "expo-local-authentication",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAF9",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "eas": {
        "projectId": "fb84b683-8af4-454a-bad6-8be5daba3711"
      }
    }
  }
}
